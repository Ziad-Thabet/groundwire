// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum WorkspacePlan {
  demo
  free
  pro
}

enum MemberRole {
  owner
  admin
  member
}

model Workspace {
  id        String        @id @default(uuid())
  name      String
  plan      WorkspacePlan @default(free)
  createdAt DateTime      @default(now())
  deletedAt DateTime?

  members       WorkspaceMember[]
  documents     Document[]
  conversations Conversation[]
  invites       Invite[]
  activityLogs  ActivityLog[]
  usageCounters UsageCounter[]

  @@map("workspaces")
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String    @map("password_hash")
  name                   String
  createdAt              DateTime  @default(now()) @map("created_at")
  deletedAt              DateTime? @map("deleted_at")
  passwordResetTokenHash String?   @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  memberships   WorkspaceMember[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model WorkspaceMember {
  id          String     @id @default(uuid())
  workspaceId String     @map("workspace_id")
  userId      String     @map("user_id")
  role        MemberRole
  createdAt   DateTime   @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  deviceLabel String?   @map("device_label")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

enum DocumentStatus {
  processing
  ready
  failed
  duplicate_pending
}

model Document {
  id          String         @id @default(uuid())
  workspaceId String         @map("workspace_id")
  uploadedBy  String         @map("uploaded_by")
  filename    String
  fileHash    String         @map("file_hash")
  status      DocumentStatus @default(processing)
  failReason  String?        @map("fail_reason")
  pageCount   Int?           @map("page_count")
  createdAt   DateTime       @default(now()) @map("created_at")
  deletedAt   DateTime?      @map("deleted_at")

  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  chunks    DocumentChunk[]

  @@index([workspaceId])
  @@index([workspaceId, fileHash])
  @@map("documents")
}

model DocumentChunk {
  id             String                       @id @default(uuid())
  documentId     String                       @map("document_id")
  content        String
  embedding      Unsupported("vector(1536)")?
  embeddingModel String                       @map("embedding_model")
  chunkIndex     Int                          @map("chunk_index")
  createdAt      DateTime                     @default(now()) @map("created_at")

  document  Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  citations MessageCitation[]

  @@unique([documentId, chunkIndex])
  @@map("document_chunks")
}

enum MessageRole {
  user
  assistant
}

model Conversation {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  title       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  messages  Message[]

  @@index([workspaceId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  truncated      Boolean     @default(false)
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  citations    MessageCitation[]

  @@index([conversationId])
  @@map("messages")
}

model MessageCitation {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  chunkId   String   @map("chunk_id")
  createdAt DateTime @default(now()) @map("created_at")

  message Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chunk   DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_citations")
}

enum InviteStatus {
  pending
  accepted
  expired
}

model UsageCounter {
  id            String   @id @default(uuid())
  workspaceId   String   @map("workspace_id")
  month         DateTime
  documentsUsed Int      @default(0) @map("documents_used")
  queriesUsed   Int      @default(0) @map("queries_used")
  tz            String   @default("UTC")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, month])
  @@map("usage_counters")
}

model ProcessedWebhookEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique @map("stripe_event_id")
  processedAt   DateTime @default(now()) @map("processed_at")
  expiresAt     DateTime @map("expires_at")

  @@map("processed_webhook_events")
}

model Invite {
  id          String       @id @default(uuid())
  workspaceId String       @map("workspace_id")
  email       String
  token       String       @unique
  expiresAt   DateTime     @map("expires_at")
  status      InviteStatus @default(pending)

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@map("invites")
}

model ActivityLog {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  actorUserId String   @map("actor_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@map("activity_logs")
}
